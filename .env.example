HOST=127.0.0.1
PORT=7676

# Owner password generated by `localspace init` in ~/.localspace/auth.json.
# Set this only for non-interactive or fully env-driven deployments.
# LOCALSPACE_OAUTH_OWNER_TOKEN=change-me-to-a-long-random-secret

# Optional OAuth tuning.
# LOCALSPACE_OAUTH_ACCESS_TOKEN_TTL_SECONDS=3600
# LOCALSPACE_OAUTH_REFRESH_TOKEN_TTL_SECONDS=2592000
# LOCALSPACE_OAUTH_SCOPES=localspace
# LOCALSPACE_OAUTH_ALLOWED_REDIRECT_HOSTS=chatgpt.com,localhost,127.0.0.1

LOCALSPACE_ALLOWED_ROOTS=/home/you/personal,/home/you/work

# For temporary tunnels, prefer setting this per run. LocalSpace derives the
# inbound Host allowlist from this URL.
# LOCALSPACE_PUBLIC_BASE_URL=https://your-public-host.example.com

# Advanced escape hatch. `*` disables Host header allowlist protection.
# LOCALSPACE_ALLOWED_HOSTS=localhost,127.0.0.1,your-public-host.example.com

# minimal | full | codex | hybrid. Defaults to hybrid.
LOCALSPACE_TOOL_MODE=hybrid

# off | changes | full. Defaults to full.
# changes exposes the aggregate show_changes tool instead of per-tool iframes.
LOCALSPACE_WIDGETS=full

LOCALSPACE_LOG_LEVEL=info
LOCALSPACE_LOG_FORMAT=json
LOCALSPACE_LOG_REQUESTS=1
LOCALSPACE_LOG_ASSETS=0
LOCALSPACE_LOG_TOOL_CALLS=1
LOCALSPACE_LOG_SHELL_COMMANDS=0
# LOCALSPACE_TRUST_PROXY=1

# LOCALSPACE_STATE_DIR=/home/you/.local/share/localspace
# LOCALSPACE_WORKTREE_ROOT=/home/you/.localspace/worktrees

# Skills are enabled by default. Set LOCALSPACE_SKILLS=0 to hide them.
# LOCALSPACE_SKILLS=0
# LOCALSPACE_AGENT_DIR=/home/you/.codex
# LOCALSPACE_SKILL_PATHS=/home/you/.codex/skills,/home/you/.claude/skills

# Legacy DEVSPACE_* configuration files may still be read for migration, but
# OAuth scopes intentionally use LOCALSPACE_OAUTH_SCOPES only.
